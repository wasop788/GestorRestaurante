<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.restaurante.controller.MesasController"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #2196F3; -fx-padding: 10 15 10 15;">
            <Label text="🍽 Gestor Restaurante"
                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUsuario"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"/>
            <Button fx:id="btnGestionUsuarios" text="Usuarios"
                    onAction="#abrirGestionUsuarios"
                    style="-fx-background-color: white; -fx-text-fill: #333;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button fx:id="btnGestionMesas" text="Mesas"
                    onAction="#abrirGestionMesas"
                    style="-fx-background-color: white; -fx-text-fill: #333;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="Carta" onAction="#abrirCarta"
                    style="-fx-background-color: white; -fx-text-fill: #2196F3;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button fx:id="btnConfiguracion" text="Config."
                    onAction="#abrirConfiguracion"
                    style="-fx-background-color: white; -fx-text-fill: #333;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
            <Button text="Salir" onAction="#cerrarSesion"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-cursor: hand; -fx-font-size: 12px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" alignment="TOP_CENTER">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="Selecciona una mesa"
                   style="-fx-font-size: 15px; -fx-text-fill: #555;"/>
            <FlowPane fx:id="flowMesas" hgap="15" vgap="15" alignment="CENTER"/>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER"
              style="-fx-padding: 10; -fx-background-color: #eeeeee;">
            <Label text="🟢 Libre" style="-fx-font-size: 12px;"/>
            <Label text="🔴 Ocupada" style="-fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>