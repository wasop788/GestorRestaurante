<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.restaurante.controller.ConfiguracionController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #333; -fx-padding: 10 20 10 20;">
            <Button text="← Volver" onAction="#volver"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Label text="Configuración del Restaurante"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" alignment="TOP_CENTER" maxWidth="420">
            <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>

            <Label text="Estos datos aparecerán en los tickets PDF generados."
                   style="-fx-font-size: 12px; -fx-text-fill: #777;"/>

            <Label text="Nombre del restaurante"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtNombre" promptText="Nombre del restaurante"/>

            <Label text="Dirección"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtDireccion" promptText="Calle, número, ciudad"/>

            <Label text="Teléfono"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtTelefono" promptText="Teléfono de contacto"/>

            <Label text="CIF"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtCif" promptText="CIF del negocio"/>

            <Button text="Guardar cambios" onAction="#guardar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-pref-height: 36px;"/>

            <Label fx:id="lblMensaje" text=""
                   style="-fx-font-size: 12px;"/>
        </VBox>
    </center>
</BorderPane>