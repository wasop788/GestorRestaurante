<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.restaurante.controller.GestionMesasController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #333; -fx-padding: 10 20 10 20;">
            <Button text="← Volver" onAction="#volver"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Label text="Gestión de Mesas"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <SplitPane>
            <!-- Tabla de mesas -->
            <TableView fx:id="tableMesas" minWidth="380">
                <columns>
                    <TableColumn fx:id="colNumero" text="Número" prefWidth="100"/>
                    <TableColumn fx:id="colCapacidad" text="Capacidad" prefWidth="100"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="150"/>
                </columns>
            </TableView>

            <!-- Formulario -->
            <VBox spacing="12" minWidth="280">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                <Label text="Datos de la mesa"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtNumero" promptText="Número de mesa"/>
                <TextField fx:id="txtCapacidad" promptText="Capacidad (personas)"/>
                <HBox spacing="10">
                    <Button text="Guardar" onAction="#guardar" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;"/>
                    <Button text="Nueva" onAction="#nueva" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;"/>
                </HBox>
                <Button text="Eliminar" onAction="#eliminar" maxWidth="Infinity"
                        style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Label fx:id="lblMensaje" text=""
                       style="-fx-font-size: 12px;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>