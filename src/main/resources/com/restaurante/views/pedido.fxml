<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.restaurante.controller.PedidoController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #333; -fx-padding: 10 20 10 20;">
            <Button text="← Volver" onAction="#volver"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Label fx:id="lblTitulo" text="Pedido"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblTotal"
                   style="-fx-text-fill: #4CAF50; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <SplitPane>
            <!-- Panel izquierdo: productos disponibles -->
            <VBox spacing="10" minWidth="350">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>
                <Label text="Carta" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbCategoria" onAction="#filtrarProductos"
                          promptText="Filtrar por categoría" maxWidth="Infinity"/>
                <ListView fx:id="listProductos" VBox.vgrow="ALWAYS"/>
                <Button text="➕ Añadir al pedido" onAction="#agregarProducto"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 36px;"/>
            </VBox>

            <!-- Panel derecho: líneas del pedido -->
            <VBox spacing="10" minWidth="350">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>
                <Label text="Pedido actual" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TableView fx:id="tablePedido" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProducto" text="Producto" prefWidth="160"/>
                        <TableColumn fx:id="colCantidad" text="Cant." prefWidth="50"/>
                        <TableColumn fx:id="colPrecio" text="Precio" prefWidth="65"/>
                        <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="75"/>
                    </columns>
                </TableView>
                <Button text="💳 Cobrar y cerrar mesa" onAction="#cobrar"
                        maxWidth="Infinity"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 36px;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>